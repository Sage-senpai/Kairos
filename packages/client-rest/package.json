{
  "name": "@kairos/client-rest",
  "version": "0.1.0",
  "description": "KAIROS REST client — an Express server exposing an agent over HTTP.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@kairos/core": "workspace:*",
    "express": "^5.2.0"
  },
  "devDependencies": {
    "@mysten/sui": "^1.45.0",
    "@types/express": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sage-senpai/Kairos.git",
    "directory": "packages/client-rest"
  },
  "homepage": "https://github.com/Sage-senpai/Kairos#readme",
  "bugs": "https://github.com/Sage-senpai/Kairos/issues",
  "publishConfig": {
    "access": "public"
  }
}
