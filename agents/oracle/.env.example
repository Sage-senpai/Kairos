# Oracle agent environment — copy to .env and fill in. NEVER commit .env.

SUI_PRIVATE_KEY=suiprivkey1_REPLACE_WITH_YOUR_KEY
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

PORT=3001
LOG_LEVEL=info

# How often Oracle publishes a market summary (ms). Default 3600000 (1 hour).
ORACLE_INTERVAL_MS=3600000
